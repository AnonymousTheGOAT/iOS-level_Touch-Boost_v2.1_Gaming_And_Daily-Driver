#=================================================
#=Customized NVTCapacitiveTouchScreen.idc file
#=Version : 2.1         Version code : 21
#=AnnonymousTheGOAT#1 annonymousthegoat1@gmail.com
#=================================================

device.internal=1
touch.deviceType=touchScreen
touch.orientationAware=1                

touch.size.calibration=geometric
touch.size.scale=1
touch.size.bias=0
touch.size.isSummed=0

touch.pressure.calibration=amplitude
touch.pressure.scale=0.0005

touch.orientation.calibration=interpolated

touch.distance.calibration=area
touch.distance.scale=0
touch.coverage.calibration=box
 
touch.gestureMode=spots